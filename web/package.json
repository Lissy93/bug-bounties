{
  "name": "web",
  "type": "module",
  "version": "0.0.1",
  "description": "Searchable database of bug bounty and responsible disclosure programs",
  "author": "Alicia Sykes",
  "license": "MIT",
  "homepage": "https://bug-bounties.as93.net",
  "repository": {
    "type": "git",
    "url": "https://github.com/Lissy93/bug-bounties"
  },
  "keywords": [
    "bug-bounty",
    "security",
    "responsible-disclosure",
    "vulnerability"
  ],
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "build": "astro check && astro build",
    "preview": "astro preview",
    "astro": "astro",
    "type-check": "astro check && svelte-check --tsconfig ./tsconfig.json",
    "lint": "eslint .",
    "format": "prettier --check 'src/**/*.{astro,svelte,ts,js,css}'",
    "fix": "eslint . --fix && prettier --write 'src/**/*.{astro,svelte,ts,js,css}'",
    "check": "npm run type-check && npm run lint && npm run format"
  },
  "overrides": {
    "yaml": "^2.8.3",
    "path-to-regexp": "^6.3.0",
    "uuid": "^14.0.0"
  },
  "dependencies": {
    "@astrojs/node": "^10.0.6",
    "astro": "^6.2.1",
    "es-module-lexer": "^2.1.0",
    "js-yaml": "^4.1.1",
    "p-limit": "^7.3.0",
    "sirv": "^3.0.2"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@astrojs/netlify": "^7.0.8",
    "@astrojs/sitemap": "^3.7.2",
    "@astrojs/svelte": "^8.1.0",
    "@astrojs/vercel": "^10.0.6",
    "@types/js-yaml": "^4.0.9",
    "@typescript-eslint/parser": "^8.59.1",
    "eslint": "^10.2.1",
    "eslint-plugin-astro": "^1.7.0",
    "eslint-plugin-svelte": "^3.17.1",
    "lucide-svelte": "^0.577.0",
    "prettier": "^3.8.3",
    "prettier-plugin-astro": "^0.14.1",
    "prettier-plugin-svelte": "^3.5.1",
    "rehype-external-links": "^3.0.0",
    "sass": "^1.99.0",
    "svelte": "^5.55.5",
    "svelte-check": "^4.4.6",
    "tslib": "^2.8.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.59.1"
  }
}
