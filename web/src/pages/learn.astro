---
import Header from "../components/Header.astro";
import DefaultLayout from "../layouts/DefaultLayout.astro";

const resources = [
  {
    name: "PortSwigger Web Security Academy",
    url: "https://portswigger.net/web-security",
    description: "Interactive labs and learning paths",
  },
  {
    name: "OWASP Top 10 2025",
    url: "https://owasp.org/Top10/",
    description: "The most critical web app security risks",
  },
  {
    name: "Hacker101",
    url: "https://www.hacker101.com/",
    description: "Free training with CTF challenges from HackerOne",
  },
  {
    name: "Bugcrowd University",
    url: "https://www.bugcrowd.com/hackers/bugcrowd-university/",
    description: "Bug hunting methodology modules",
  },
  {
    name: "OWASP WebGoat",
    url: "https://owasp.org/www-project-webgoat/",
    description: "Deliberately vulnerable app for practice",
  },
  {
    name: "TryHackMe",
    url: "https://tryhackme.com/",
    description: "Gamified rooms and learning paths",
  },
  {
    name: "PentesterLab",
    url: "https://pentesterlab.com/",
    description: "Hands-on web security exercises",
  },
  {
    name: "HackTheBox Academy",
    url: "https://academy.hackthebox.com/",
    description: "Structured offensive security courses",
  },
];

const glossaryTerms = [
  {
    term: "Bug Bounty",
    definition:
      "A program where organizations pay researchers for finding and reporting security vulnerabilities.",
  },
  {
    term: "VDP",
    definition:
      "Vulnerability Disclosure Program. Like a bug bounty but without monetary rewards - a channel for reporting issues responsibly.",
  },
  {
    term: "CVE",
    definition:
      "Common Vulnerabilities and Exposures. A unique identifier (e.g. CVE-2024-1234) assigned to a publicly known vulnerability.",
  },
  {
    term: "CVSS",
    definition:
      "Common Vulnerability Scoring System. A standard for rating vulnerability severity on a 0-10 scale.",
  },
  {
    term: "CWE",
    definition:
      "Common Weakness Enumeration. A categorized list of software and hardware weakness types.",
  },
  {
    term: "Safe Harbor",
    definition:
      "A legal agreement that protects researchers from prosecution when they follow the program's rules.",
  },
  {
    term: "Scope",
    definition:
      "The set of assets (domains, apps, APIs) that a program authorizes you to test.",
  },
  {
    term: "Triager",
    definition:
      "A person who reviews incoming vulnerability reports, validates them, and assigns severity.",
  },
  {
    term: "PoC",
    definition:
      "Proof of Concept. A demonstration that proves a vulnerability exists and can be exploited.",
  },
  {
    term: "Coordinated Disclosure",
    definition:
      "A process where the researcher and vendor agree on a timeline before the vulnerability is made public.",
  },
  {
    term: "security.txt",
    definition:
      "A standard file (/.well-known/security.txt) that tells researchers how to report vulnerabilities to a site.",
  },
  {
    term: "CFAA",
    definition:
      "Computer Fraud and Abuse Act. US federal law governing unauthorized computer access - relevant to legal boundaries.",
  },
  {
    term: "Zero-day",
    definition:
      "A vulnerability that is unknown to the vendor and has no available patch.",
  },
  {
    term: "Severity",
    definition:
      "The rated impact of a vulnerability, typically Critical, High, Medium, Low, or Informational.",
  },
  {
    term: "Duplicate",
    definition:
      "A report for a vulnerability that has already been reported by another researcher.",
  },
  {
    term: "CNA",
    definition:
      "CVE Numbering Authority. An organization authorized to assign CVE identifiers to vulnerabilities.",
  },
];

const jsonLd = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Article",
      headline: "Bug Bounty Reporting Guide",
      description:
        "A practical guide to writing and submitting your first bug bounty report.",
      author: {
        "@type": "Organization",
        name: "Bug Bounties",
        url: "https://bug-bounties.as93.net",
      },
      publisher: {
        "@type": "Organization",
        name: "Bug Bounties",
        url: "https://bug-bounties.as93.net",
      },
      mainEntityOfPage: "https://bug-bounties.as93.net/learn",
    },
    {
      "@type": "BreadcrumbList",
      itemListElement: [
        {
          "@type": "ListItem",
          position: 1,
          name: "Home",
          item: "https://bug-bounties.as93.net/",
        },
        {
          "@type": "ListItem",
          position: 2,
          name: "Learn",
          item: "https://bug-bounties.as93.net/learn",
        },
      ],
    },
  ],
};
---

<DefaultLayout
  title="Bug Bounty Reporting Guide - Bug Bounties"
  description="A practical guide to writing and submitting your first bug bounty report. Covers report structure, submission process, legal considerations, and essential resources."
  jsonLd={jsonLd}
>
  <Header />
  <article class="learn">
    <h1>Bug Bounty Reporting Guide</h1>
    <p class="subtitle">
      A practical reference for writing and submitting your first vulnerability
      report.
    </p>

    <nav class="toc">
      <a href="#what-is-a-bug-bounty">What is a bug bounty?</a>
      <a href="#before-you-start">Before you start</a>
      <a href="#finding-vulnerabilities">Finding vulnerabilities</a>
      <a href="#writing-the-report">Writing the report</a>
      <a href="#submitting">Submitting</a>
      <a href="#disclosure">Disclosure</a>
      <a href="#staying-legal">Staying legal</a>
      <a href="#glossary">Glossary</a>
    </nav>

    <section id="what-is-a-bug-bounty">
      <h2>What is a bug bounty?</h2>
      <p>
        A bug bounty is a reward offered by an organization for finding and
        reporting security vulnerabilities in their systems. Programs define
        what you can test, how to report, and what you get in return - sometimes
        money, sometimes just recognition. A Vulnerability Disclosure Program
        (VDP) is similar but typically does not offer monetary rewards. Both
        exist to give researchers a safe, authorized way to report issues.
      </p>
    </section>

    <section id="before-you-start">
      <h2>Before you start</h2>

      <h3>Read the program rules</h3>
      <p>
        Every program has a policy page. Read it completely before doing
        anything. It tells you what is allowed, what is off-limits, and how they
        want to receive reports.
      </p>

      <h3>Understand scope</h3>
      <p>
        Scope defines which assets you are authorized to test - specific
        domains, apps, APIs, or IP ranges. Testing anything outside scope can
        get your report rejected or, worse, get you into legal trouble. When in
        doubt, ask the program before testing.
      </p>

      <h3>Check safe harbor and legal terms</h3>
      <p>
        Safe harbor clauses protect you from legal action when you follow the
        rules. Not all programs offer this. If a program has no safe harbor
        language, proceed with extra caution. Some programs reference specific
        legal frameworks - understand what they cover.
      </p>
    </section>

    <section id="finding-vulnerabilities">
      <h2>Finding vulnerabilities</h2>
      <p>
        Learning to find bugs takes practice. These resources cover the
        fundamentals of web security testing, from injection flaws to
        authentication bypasses.
      </p>
      <div class="resource-grid">
        {
          resources.map((r) => (
            <a
              class="resource-card"
              href={r.url}
              target="_blank"
              rel="noopener noreferrer"
            >
              <strong>{r.name}</strong>
              <span>{r.description}</span>
            </a>
          ))
        }
      </div>
    </section>

    <section id="writing-the-report">
      <h2>Writing the report</h2>

      <h3>What to include</h3>
      <ul>
        <li>
          <strong>Title</strong> - a clear, specific summary of the vulnerability
        </li>
        <li>
          <strong>Description</strong> - what the vulnerability is and where it exists
        </li>
        <li>
          <strong>Steps to reproduce</strong> - exact steps anyone can follow to trigger
          the bug
        </li>
        <li>
          <strong>Impact</strong> - what an attacker could do with this vulnerability
        </li>
        <li>
          <strong>Severity</strong> - your assessment using CVSS or the program's
          rating system
        </li>
        <li>
          <strong>Proof of Concept</strong> - screenshots, videos, HTTP requests,
          or scripts
        </li>
        <li>
          <strong>Environment</strong> - browser, OS, tools, and any specific configuration
          used
        </li>
      </ul>

      <h3>Report template</h3>
      <pre
        class="report-template">## Title
[Type of vulnerability] in [affected component]

## Description
[What the vulnerability is and why it matters]

## Steps to Reproduce
1. Go to [URL]
2. [Action]
3. [Action]
4. Observe [result]

## Impact
[What an attacker could achieve - data access, privilege escalation, etc.]

## Severity
[Critical / High / Medium / Low] - CVSS: [score]

## Proof of Concept
[Screenshots, code snippets, HTTP requests]

## Environment
- Browser: [e.g. Chrome 120]
- OS: [e.g. Ubuntu 24.04]
- Tools: [e.g. Burp Suite Community]</pre>

      <h3>Common mistakes</h3>
      <ul>
        <li>Writing vague descriptions without technical detail</li>
        <li>Missing or incomplete reproduction steps</li>
        <li>Inflating severity to try to get a higher payout</li>
        <li>Reporting issues that are out of scope for the program</li>
        <li>Not checking for duplicates before submitting</li>
        <li>Using threatening or aggressive language</li>
      </ul>
    </section>

    <section id="submitting">
      <h2>Submitting your report</h2>

      <h3>Finding the right channel</h3>
      <p>
        Check for a <code>security.txt</code> file at <code
          >/.well-known/security.txt</code
        > on the target domain. Many companies use platforms like HackerOne, Bugcrowd,
        or Intigriti - submit through the platform if one exists. If neither is available,
        look for a security contact email (often <code
          >security@company.com</code
        >).
      </p>

      <h3>After you submit</h3>
      <ol>
        <li>
          <strong>Acknowledgment</strong> - the program confirms they received your
          report
        </li>
        <li>
          <strong>Triage</strong> - a triager validates the vulnerability and assesses
          severity
        </li>
        <li>
          <strong>Clarification</strong> - you may be asked for more details or to
          verify a fix
        </li>
        <li><strong>Fix</strong> - the vendor patches the vulnerability</li>
        <li>
          <strong>Disclosure</strong> - the report may be published, depending on
          the program's policy
        </li>
      </ol>

      <h3>Handling responses</h3>
      <ul>
        <li>
          <strong>Silence</strong> - wait at least 2 weeks before following up. Platforms
          usually have SLA timers.
        </li>
        <li>
          <strong>Rejection</strong> - ask for a clear reason. If you disagree, provide
          additional evidence calmly.
        </li>
        <li>
          <strong>Lowballed severity</strong> - respond with a clear explanation of
          impact, referencing CVSS if possible.
        </li>
        <li>
          <strong>Clarification requests</strong> - respond promptly with the details
          asked for. This speeds up resolution.
        </li>
      </ul>
    </section>

    <section id="disclosure">
      <h2>Disclosure timeline</h2>
      <p>
        The industry standard is 90 days - after reporting, the vendor gets 90
        days to fix the issue before the researcher may disclose it publicly.
        This is sometimes called "coordinated disclosure."
      </p>
      <p>
        Some programs have their own timelines. Always check the program's
        disclosure policy first. If you want to publish a writeup after a fix,
        confirm with the program that they are comfortable with it.
      </p>
      <p>
        If a vendor is unresponsive after repeated follow-ups, you may consider
        escalating through a CERT (like CERT/CC) or disclosing through a CNA.
        Full unilateral disclosure should be a last resort.
      </p>
    </section>

    <section id="staying-legal">
      <h2>Staying legal</h2>
      <ul>
        <li>Only test systems and assets that are explicitly in scope</li>
        <li>
          Understand the laws in your jurisdiction - the CFAA (US) and Computer
          Misuse Act (UK) are strict
        </li>
        <li>
          Do not access, copy, or store user data beyond what is needed to prove
          the vulnerability
        </li>
        <li>
          Never use a vulnerability for personal gain beyond the bounty reward
        </li>
        <li>Check if your employer's contracts restrict security research</li>
        <li>
          Do not threaten to disclose publicly as leverage for a payout - this
          can be treated as extortion
        </li>
        <li>Keep records of everything you do during testing</li>
      </ul>
      <p>
        <em
          >This is general guidance, not legal advice. Consult a lawyer if you
          have concerns about a specific situation.</em
        >
      </p>
    </section>

    <section id="glossary">
      <h2>Glossary</h2>
      <dl class="glossary">
        {
          glossaryTerms.map((item) => (
            <>
              <dt>{item.term}</dt>
              <dd>{item.definition}</dd>
            </>
          ))
        }
      </dl>
    </section>
  </article>
</DefaultLayout>

<style>
  .learn {
    width: var(--content-width);
    margin: 0 auto 2rem;
    color: var(--foreground);
  }
  .learn h1 {
    color: var(--primary);
    font-size: 2rem;
    margin-bottom: 0.25rem;
  }
  .subtitle {
    color: var(--muted);
    font-size: 1.05rem;
    margin-top: 0;
    margin-bottom: 1.5rem;
  }
  .toc {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 1.5rem;
  }
  .toc a {
    background: var(--background-lighter);
    color: var(--primary);
    padding: 0.35rem 0.75rem;
    border-radius: 999px;
    text-decoration: none;
    font-size: 0.85rem;
    border: 1px solid var(--border);
    transition: background var(--transition);
  }
  .toc a:hover {
    background: var(--primary);
    color: var(--background);
  }
  section[id] {
    scroll-margin-top: 4rem;
  }
  section {
    background: var(--background-lighter);
    border-radius: var(--curve);
    padding: 1.25rem;
    margin-bottom: 1rem;
  }
  h2 {
    margin-top: 0;
    font-size: 1.1rem;
    color: var(--primary);
  }
  h3 {
    font-size: 0.95rem;
    color: var(--foreground);
    margin: 1rem 0 0.4rem;
  }
  p {
    line-height: 1.6;
    margin: 0.5rem 0;
  }
  ul,
  ol {
    padding-left: 1.5rem;
    line-height: 1.6;
  }
  li {
    margin-bottom: 0.3rem;
  }
  a {
    color: var(--primary);
  }
  code {
    background: var(--background-darker);
    padding: 0.15rem 0.4rem;
    border-radius: var(--curve);
    font-size: 0.85rem;
  }
  .resource-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 0.75rem;
    margin-top: 0.75rem;
  }
  .resource-card {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    background: var(--background);
    border: 1px solid var(--border);
    border-radius: var(--curve);
    padding: 0.85rem 1rem;
    text-decoration: none;
    transition: border-color var(--transition);
  }
  .resource-card:hover {
    border-color: var(--primary);
  }
  .resource-card strong {
    color: var(--primary);
    font-size: 0.9rem;
  }
  .resource-card span {
    color: var(--muted);
    font-size: 0.85rem;
    line-height: 1.4;
  }
  .report-template {
    background: var(--background);
    padding: 1rem 1.25rem;
    border-radius: var(--curve);
    border-left: 3px solid var(--primary);
    font-size: 0.8rem;
    line-height: 1.5;
    overflow-x: auto;
    max-width: 100%;
  }
  .glossary {
    columns: 2;
    column-gap: 2rem;
  }
  .glossary dt {
    font-weight: bold;
    color: var(--primary);
    font-size: 0.9rem;
    margin-top: 0.75rem;
    break-after: avoid;
  }
  .glossary dt:first-child {
    margin-top: 0;
  }
  .glossary dd {
    margin-left: 0;
    margin-bottom: 0.5rem;
    font-size: 0.85rem;
    line-height: 1.5;
    color: var(--muted);
    break-inside: avoid;
  }
  @media (max-width: 600px) {
    .glossary {
      columns: 1;
    }
  }
</style>
