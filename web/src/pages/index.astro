---
import Header from "@components/Header.astro";
import SearchableList from "@components/SearchableList.svelte";
import StatsBar from "@components/StatsBar.astro";
import LookupSearch from "@components/LookupSearch.svelte";
import DefaultLayout from "@layouts/DefaultLayout.astro";
import { loadAllPrograms } from "@lib/load-all-programs";
import { homeSchema } from "@lib/json-ld";

const { programs, listPrograms, trancoRanks, kevCounts } =
  await loadAllPrograms();

const totalPrograms = programs.length;
const withBounties = programs.filter((p) =>
  p.rewards?.includes("*bounty"),
).length;
const withSafeHarbor = programs.filter((p) => p.safe_harbor).length;

const jsonLd = homeSchema(
  `Browse ${totalPrograms.toLocaleString()} bug bounty and responsible disclosure programs.`,
);
---

<DefaultLayout
  title="Bug Bounties - Directory of Bug Bounty Programs"
  description={`Browse ${totalPrograms.toLocaleString()} bug bounty and responsible disclosure programs. Find companies that welcome vulnerability reports, with scopes, rewards and contact details.`}
  jsonLd={jsonLd}
>
  <Header />
  <div class="entrypoint-cards">
    <section class="lookup-card">
      <h2>Find Reporting Method</h2>
      <p>
        Discovered a security vulnerability on a website, and not sure where to
        report it? Enter the URL to a website, repo, app or software package,
        and we'll search all VDPs, bounties and security contact methods to find
        you the best channel to securely disclose the vulnerability.
      </p>
      <LookupSearch bare client:idle />
    </section>
    <section class="api-card">
      <h2>Query From Your Tools</h2>
      <p>
        Query the bug-bounty database from your AI agent, pen-test toolchain or
        scripts
      </p>
      <ul class="endpoints">
        <li>
          <span class="tag">MCP</span>
          <div class="lead">
            <span>For Claude Desktop, Cursor, Cline and other MCP clients</span>
            <a href="/mcp" title="MCP Documentation">Docs →</a>
          </div>
          <code>npx bug-bounties-mcp</code>
        </li>
        <li>
          <span class="tag">API</span>
          <div class="lead">
            <span>JSON endpoints for programmatically searching VDPs</span>
            <a href="/api" title="API Documentation">Docs →</a>
          </div>
          <code>bug-bounties.as93.net/api</code>
        </li>
      </ul>
    </section>
  </div>
  <hr />
  <SearchableList
    programs={listPrograms}
    {trancoRanks}
    {kevCounts}
    client:idle
  />
  <hr />
  <StatsBar {totalPrograms} {withBounties} {withSafeHarbor} />
</DefaultLayout>

<style>
  hr {
    border: none;
    border-top: 2px solid var(--border);
    margin: 1.6rem auto;
    width: var(--content-width, 90%);
  }
  .entrypoint-cards {
    display: flex;
    gap: 1rem;
    width: var(--content-width);
    margin: 0 auto 1rem;
  }
  .lookup-card,
  .api-card {
    padding: 1.25rem;
    background: var(--background-lighter);
    border-radius: var(--curve);
    flex: 1;
    & h2 {
      margin: 0 0 0.35rem;
      font-size: 1.1rem;
      color: var(--primary);
    }
    & > p {
      margin: 0 0 0.75rem;
      font-size: 0.85rem;
      line-height: 1.5;
      color: var(--muted);
    }
  }
  .endpoints {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .endpoints li {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 0.15rem 0.6rem;
    align-items: center;
    padding: 0.55rem 0.7rem;
    background: var(--background);
    border: 1px solid var(--border);
    border-radius: var(--curve);
  }
  .endpoints .tag {
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--primary);
    background: color-mix(in srgb, var(--primary) 15%, transparent);
    padding: 0.1rem 0.45rem;
    border-radius: 999px;
    width: max-content;
  }
  .endpoints .lead {
    font-size: 0.8rem;
    line-height: 1.35;
    color: var(--muted);
    display: flex;
    justify-content: space-between;
    align-items: anchor-center;
    a {
      overflow: hidden;
    }
  }
  .endpoints code,
  .endpoints a {
    grid-column: 1 / -1;
    font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
    font-size: 0.82rem;
    color: var(--foreground);
    background: var(--background-darker);
    padding: 0.35rem 0.55rem;
    border-radius: var(--curve);
    user-select: all;
    overflow-x: auto;
    white-space: nowrap;
    text-decoration: none;
  }
  .endpoints a:hover {
    color: var(--primary);
  }
  @media (max-width: 720px) {
    .entrypoint-cards {
      flex-direction: column;
    }
  }
</style>
