---
import Header from '../components/Header.astro';
import SearchableList from '../components/SearchableList.svelte';
import Tooltip from '../components/Tooltip.svelte';
import DefaultLayout from '../layouts/DefaultLayout.astro';
import { loadBounties } from '../lib/data';
import { fetchTrancoRanks } from '../lib/tranco';
import { fetchCisaKev } from '../lib/cisa-kev';
import { fetchAllPlatformData } from '../lib/platform-data';
import { fetchDiscloseData } from '../lib/disclose-data';
import { log } from '../lib/log';
import { tips } from '../lib/tooltips';
import type { BountyProgram, ListProgram } from '../types/Company';

const rawPrograms = loadBounties();

// Fetch enrichment data - each gracefully degrades to empty if it fails
let trancoRanks: Record<string, number> = {};
let kevCounts: Record<string, number> = {};
let programs: BountyProgram[] = rawPrograms;
try {
  const [trancoData, kevMap, platformDataMap, discloseMap] = await Promise.all([
    fetchTrancoRanks(rawPrograms),
    fetchCisaKev(rawPrograms),
    fetchAllPlatformData(rawPrograms),
    fetchDiscloseData(rawPrograms),
  ]);
  for (const [slug, rank] of trancoData.bySlug) {
    trancoRanks[slug] = rank;
  }
  for (const [slug, data] of kevMap) {
    kevCounts[slug] = data.totalCount;
  }

  // Enrich programs with platform + Disclose metadata for filtering/display
  programs = rawPrograms.map((p) => {
    const pd = platformDataMap.get(p.slug);
    const dd = discloseMap.get(p.slug);
    if (!pd && !dd) return p;

    const enriched: BountyProgram = { ...p };
    if (pd) {
      enriched.min_payout ??= pd.minPayout;
      enriched.max_payout ??= pd.maxPayout;
      enriched.managed ??= pd.managed;
      enriched.safe_harbor ??= pd.safeHarbor;
      enriched.handle ??= pd.handle;
      if (!enriched.rewards?.length && pd.rewards?.length) {
        enriched.rewards = pd.rewards;
      }
      if (!enriched.domains?.length && pd.domains?.length) {
        enriched.domains = pd.domains;
      }
    }
    if (dd) {
      enriched.safe_harbor ??= dd.safeHarbor;
    }
    return enriched;
  });
} catch (err) {
  log.warn('index', 'Failed to load enrichment data', err);
}

const totalPrograms = programs.length;
const withBounties = programs.filter((p) => p.rewards?.includes('*bounty')).length;
const withSafeHarbor = programs.filter((p) => p.safe_harbor).length;

const completeness = (p: BountyProgram) =>
  Object.values(p).filter(v => v != null && v !== '' && !(Array.isArray(v) && !v.length)).length;

const listPrograms: ListProgram[] = programs.map((p) => ({
  company: p.company,
  url: p.url,
  slug: p.slug,
  handle: p.handle,
  rewards: p.rewards,
  min_payout: p.min_payout,
  max_payout: p.max_payout,
  currency: p.currency,
  safe_harbor: p.safe_harbor,
  managed: p.managed,
  domains: p.domains,
  completeness: completeness(p),
}));
---

<DefaultLayout>
  <Header />
  <div class="stats">
    <Tooltip text={tips.statPrograms}><span><strong>{totalPrograms.toLocaleString()}</strong> programs</span></Tooltip>
    <Tooltip text={tips.statBounties}><span><strong>{withBounties.toLocaleString()}</strong> with bounties</span></Tooltip>
    <Tooltip text={tips.statSafeHarbor}><span><strong>{withSafeHarbor.toLocaleString()}</strong> with safe harbor</span></Tooltip>
  </div>
  <SearchableList programs={listPrograms} {trancoRanks} {kevCounts} client:load />
</DefaultLayout>

<style>
  .stats {
    display: flex;
    justify-content: center;
    gap: 2rem;
    flex-wrap: wrap;
    margin: 0 auto 1rem;
    width: var(--content-width);
    color: var(--muted);
    font-size: 0.9rem;
  }
  .stats strong {
    color: var(--primary);
  }
</style>
