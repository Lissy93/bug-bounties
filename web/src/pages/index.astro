---
import Header from "../components/Header.astro";
import SearchableList from "../components/SearchableList.svelte";
import StatsBar from "../components/StatsBar.astro";
import LookupSearch from "../components/LookupSearch.svelte";
import DefaultLayout from "../layouts/DefaultLayout.astro";
import { loadAllPrograms } from "../lib/load-all-programs";
import { homeSchema } from "../lib/json-ld";

const { programs, listPrograms, trancoRanks, kevCounts } =
  await loadAllPrograms();

const totalPrograms = programs.length;
const withBounties = programs.filter((p) =>
  p.rewards?.includes("*bounty"),
).length;
const withSafeHarbor = programs.filter((p) => p.safe_harbor).length;

const jsonLd = homeSchema(
  `Browse ${totalPrograms.toLocaleString()} bug bounty and responsible disclosure programs.`,
);
---

<DefaultLayout
  title="Bug Bounties - Directory of Bug Bounty Programs"
  description={`Browse ${totalPrograms.toLocaleString()} bug bounty and responsible disclosure programs. Find companies that welcome vulnerability reports, with scopes, rewards and contact details.`}
  jsonLd={jsonLd}
>
  <Header />
  <section class="lookup-card">
    <h2>Find Reporting Method</h2>
    <p>
      Discovered a security vulnerability on a website, and not sure where to
      report it? Enter the website URL or GitHub repo, and we'll search across
      all disclosure programs, security contact details and bug bounties to find
      you the best channel to securely disclose the vulnerability.
    </p>
    <LookupSearch bare client:idle />
  </section>
  <hr />
  <SearchableList
    programs={listPrograms}
    {trancoRanks}
    {kevCounts}
    client:idle
  />
  <hr />
  <StatsBar {totalPrograms} {withBounties} {withSafeHarbor} />
</DefaultLayout>

<style>
  hr {
    border: none;
    border-top: 2px solid var(--border);
    margin: 1.6rem auto;
    width: var(--content-width, 90%);
  }
  .lookup-card {
    width: var(--content-width);
    margin: 0 auto 1rem;
    padding: 1.25rem;
    background: var(--background-lighter);
    border-radius: var(--curve);

    & h2 {
      margin: 0 0 0.35rem;
      font-size: 1.1rem;
      color: var(--primary);
    }

    & p {
      margin: 0 0 0.75rem;
      font-size: 0.85rem;
      line-height: 1.5;
      color: var(--muted);
    }
  }
</style>
