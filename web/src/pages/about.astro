---
import Header from "../components/Header.astro";
import DefaultLayout from "../layouts/DefaultLayout.astro";
import { loadBounties } from "../lib/data";

const programs = loadBounties();
const count = programs.length;

const apps = [
  {
    name: "Web-Check",
    url: "https://web-check.xyz",
    github: "https://github.com/lissy93/web-check",
    logo: "https://cdn.as93.net/logo/web-check?w=64&h=64",
    description: "All-in-one OSINT tool for analyzing any website",
  },
  {
    name: "Personal Security Checklist",
    url: "https://digital-defense.io/",
    github: "https://github.com/lissy93/personal-security-checklist",
    logo: "https://cdn.as93.net/logo/digital-defense?w=64&h=64",
    description: "The ultimate list of tips for protecting your data online",
  },
  {
    name: "Awesome Privacy",
    url: "https://awesome-privacy.xyz/",
    github: "https://github.com/lissy93/awesome-privacy",
    logo: "https://cdn.as93.net/logo/awesome-privacy?w=64&h=64",
    description:
      "A curated list of apps, services and alternatives that respect your privacy",
  },
  {
    name: "Portainer Templates",
    url: "https://portainer-templates.as93.net/",
    github: "https://github.com/lissy93/portainer-templates",
    logo: "https://cdn.as93.net/logo/portainer-templates?w=64&h=64",
    description: "500+ 1-click Portainer app templates",
  },
  {
    name: "Networking Toolbox",
    url: "https://networkingtoolbox.net/",
    github: "https://github.com/lissy93/networking-toolbox",
    logo: "https://cdn.as93.net/logo/networking-toolbox?w=64&h=64",
    description:
      "The all-in-one collection of 100+ free offline-first tools for sysadmins",
  },
  {
    name: "Domain Locker",
    url: "https://domain-locker.com/",
    github: "https://github.com/lissy93/domain-locker",
    logo: "https://cdn.as93.net/logo/domain-locker?w=64&h=64",
    description: "Domain name portfolio app for monitoring your domains",
  },
  {
    name: "Email Comparison",
    url: "https://email-comparison.as93.net/",
    github: "https://github.com/lissy93/email-comparison",
    logo: "https://cdn.as93.net/logo/email-comparison?w=64&h=64",
    description: "Comparison of private and / or secure email providers",
  },
  {
    name: "Dashy",
    url: "https://dashy.to/",
    github: "https://github.com/lissy93/dashy",
    logo: "https://cdn.as93.net/logo/dashy?w=64&h=64",
    description: "The self-hosted personal dashboard for your homelab",
  },
];
---

<DefaultLayout
  title="About - Bug Bounties"
  description="About the Bug Bounties directory - how data is collected and how to contribute."
>
  <Header />
  <article class="about">
    <h1>About</h1>

    <section>
      <h2>What is this?</h2>
      <p>
        Bug Bounties is an open-source directory of <strong
          >{count.toLocaleString()}</strong
        > bug bounty and responsible disclosure programs. The aim, is to help security
        researchers quickly find companies that welcome vulnerability reports, as
        well as augmenting listing with essential info like scopes, rewards, contact
        details, known issues, and more.
      </p>
    </section>

    <section>
      <h2>How is data collected?</h2>
      <p>
        Program data is aggregated from multiple public sources, which is
        fetched, processed and verified nightly. As well as user-submitted
        programs, we also fetch from HackerOne, BugCrowd, Intigriti, YesWeHack,
        Federacy, Disclose.io among other sources.
      </p>
      <p>
        Platform-managed programs are stored in <a
          href="https://github.com/Lissy93/bug-bounties/blob/main/platform-programs.yml"
          ><code>platform-programs.yml</code></a
        >, while independently-run programs are in <a
          href="https://github.com/Lissy93/bug-bounties/blob/main/independent-programs.yml"
          ><code>independent-programs.yml</code></a
        >. Both files are available in our GitHub repository.
      </p>
    </section>

    <section>
      <h2>Adding a Program</h2>
      <p>
        If your bounty program is not listed on any of the platforms which we
        auto-aggregate, you can submit it as an independent program. Fork the
        repository, add your program to <a
          href="https://github.com/Lissy93/bug-bounties/blob/main/independent-programs.yml"
          target="_blank"><code>independent-programs.yml</code></a
        >, and open a pull request. Required fields are <code>company</code> and <code
          >url</code
        >. Optional fields include <code>contact</code>,
        <code>rewards</code>, <code>safe_harbor</code>, <code>scope</code>, <code
          >payout_table</code
        >, <code>excluded_methods</code>, <code>description</code>, and more.
        See the <a
          href="https://github.com/Lissy93/bug-bounties#submitting-a-program"
          >full field reference</a
        > in the README.
      </p>
      <p>
        Alternatively, you can just use <a
          href="https://github.com/Lissy93/bug-bounties/issues/new?template=add.yml"
          target="_blank">this form</a
        >, and we will add your bounty program automatically.
      </p>
    </section>

    <section>
      <h2>Contributing</h2>

      <p>
        Start by clone the repo with <code
          >git clone git@github.com:Lissy93/bug-bounties.git &amp;&amp; cd
          bug-bounties</code
        ><br />
        You will need Python (v3.12+) installed for the scripts, as well as Node.js
        (v24+) for the website.
      </p>
      <p>To run the data gathering and processing scripts:</p>
      <ol>
        <li>
          <code>make install</code> - Setup environment and install dependencies (from
          <a
            href="https://github.com/Lissy93/bug-bounties/blob/main/lib/requirements.txt"
            ><code>requirements.txt</code></a
          >)
        </li>
        <li>
          <code>make populate</code> - Fetch the latest directory of programs, format,
          and write to <code>platform-programs.yml</code>
        </li>
        <li>
          <code>make validate</code> - Verify and validate the <a
            href="https://github.com/Lissy93/bug-bounties/blob/main/platform-programs.yml"
            ><code>platform-programs.yml</code></a
          > and <a
            href="https://github.com/Lissy93/bug-bounties/blob/main/independent-programs.yml"
            ><code>independent-programs.yml</code></a
          > files against the <a
            href="https://github.com/Lissy93/bug-bounties/blob/main/lib/schema.json"
            ><code>schema.json</code></a
          >
        </li>
        <li>
          <code>make readme</code> - Generate and insert a summarized list of programs
          into the <a
            href="https://github.com/Lissy93/bug-bounties/blob/main/.github/README.md"
            ><code>README.md</code></a
          >
        </li>
      </ol>
      <p>To develop and build the website:</p>
      <ol>
        <li>
          <code>cd web</code> to navigate into the <a
            href="https://github.com/Lissy93/bug-bounties/tree/main/web"
            ><code>web/</code></a
          > directory
        </li>
        <li><code>npm i</code> to install dependencies</li>
        <li><code>npm run dev</code> to start the development server</li>
        <li><code>npm run build</code> to build the production site</li>
      </ol>
      <p>
        If you'd like to deploy/self-host your own version or fork of
        bug-bounties, you have several options:
      </p>
      <ul>
        <li>
          <b>Option #1:</b> Upload the content of <code>web/dist/</code> into any
          web server, static hosting provider or CDN.
        </li>
        <li>
          <b>Option #2:</b> Import the project into a static hosting provider (like
          Vercel, Netlify, etc), where it will be auto-build and published
        </li>
        <li>
          <b>Option #3:</b> For Docker, run <code
            >docker run -p 8080:8080 ghcr.io/lissy93/bug-bounties:latest</code
          >
        </li>
      </ul>
    </section>

    <section>
      <h2>Responsible disclosure</h2>
      <p>
        If you find a vulnerability in one of these programs, always follow
        their specific disclosure policy. General guidance:
      </p>
      <ul>
        <li>Read the program's rules before testing</li>
        <li>Only test on systems you are authorized to test</li>
        <li>Do not access, modify, or delete user data</li>
        <li>
          Report vulnerabilities promptly and provide enough detail to reproduce
        </li>
        <li>
          Give the company reasonable time to fix before any public disclosure
        </li>
      </ul>
    </section>

    <section>
      <h2>Credits and license</h2>
      <h3>Contributors</h3>
      <a href="https://github.com/Lissy93/bug-bounties/graphs/contributors">
        <img
          src="https://readme-contribs.as93.net/contributors/lissy93/bug-bounties?shape=squircle&textColor=666666"
          alt="Top Contributors"
        />
      </a>

      <h3>Sponsors</h3>
      <a href="https://github.com/sponsors/Lissy93">
