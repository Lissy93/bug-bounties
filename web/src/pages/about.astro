    </section>
    <section>
      <h2>More Apps</h2>
      <p>
        Enjoy security content? You might be interested in some of the other
        projects we maintain:
      </p>
      <ul class="more-apps-list">
        {
          apps.map((app) => (
            <li>
              <a href={app.url} target="_blank">
                <img src={app.logo} width="20" />
                <span>{app.name}</span>
              </a>
              <span> - {app.description}</span>
              <span>
                (
                <a href={app.github} target="_blank">
                  GitHub
                </a>
                )
              </span>
            </li>
          ))
        }
      </ul>
    </section>
  </article>
</DefaultLayout>

<style>
  .about {
    width: var(--content-width);
    margin: 0 auto 2rem;
    color: var(--foreground);
  }
  .about h1 {
    color: var(--primary);
    font-size: 2rem;
  }
  section {
    background: var(--background-lighter);
    border-radius: var(--curve);
    padding: 1.25rem;
    margin-bottom: 1rem;
  }
  h2 {
    margin-top: 0;
    font-size: 1.1rem;
    color: var(--primary);
  }
  p {
    line-height: 1.6;
    margin: 0.5rem 0;
  }
  ul {
    padding-left: 1.5rem;
    line-height: 1.6;
  }
  a {
    color: var(--primary);
  }
  img {
    max-width: 100%;
  }
  code {
    background: var(--background-darker);
    padding: 0.15rem 0.4rem;
    border-radius: var(--curve);
    font-size: 0.85rem;
  }
  .license {
    width: fit-content;
    background: var(--background);
    max-width: calc(100% - 2rem);
    overflow-x: auto;
    padding: 0.5rem 1rem;
    border-radius: 4px;
    font-size: 0.75rem;
  }

  .more-apps-list {
    padding: 0;
    margin: 0.25rem 0;
    li {
      display: flex;
      gap: 0.25rem;
      line-height: 24px;
    }
    a {
      display: inline-flex;
      gap: 0.25rem;
      align-items: anchor-center;
    }
