          src="https://readme-contribs.as93.net/sponsors/lissy93?shape=squircle&textColor=666666"
          alt="Sponsors"
        />
      </a>

      <h3>Dependencies</h3>
      <ul>
        <li>
          <a href="https://astro.build">Astro</a> + <a href="https://svelte.dev"
            >Svelte</a
          > - website
        </li>
        <li><a href="https://pyyaml.org">PyYAML</a> - YAML parsing</li>
        <li>
          <a href="https://python-jsonschema.readthedocs.io">jsonschema</a> - schema
          validation
        </li>
        <li>
          <a href="https://github.com/rapidfuzz/RapidFuzz">rapidfuzz</a> - fuzzy deduplication
        </li>
        <li>
          <a href="https://requests.readthedocs.io">requests</a> - HTTP client
