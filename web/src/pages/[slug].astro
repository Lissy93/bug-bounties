---
import DefaultLayout from '../layouts/DefaultLayout.astro';
import Header from '../components/Header.astro';
import BackLink from '../components/BackLink.astro';
import FaviconImage from '../components/FaviconImage.svelte';
import RewardBadges from '../components/RewardBadges.svelte';
import Tooltip from '../components/Tooltip.svelte';
import Icon from '../components/Icon.svelte';
import { loadBounties } from '../lib/data';
import { formatPayout, formatDuration, getHostname } from '../lib/format';
import { tips } from '../lib/tooltips';
import type { BountyProgram } from '../types/Company';

export function getStaticPaths() {
  const programs = loadBounties();
  return programs.map((program) => ({
    params: { slug: program.slug },
    props: { program },
  }));
}

interface Props {
  program: BountyProgram;
}

const { program } = Astro.props;

const payout = formatPayout(program.min_payout, program.max_payout, program.currency);
const responseTime = formatDuration(program.response_time);
const bountyTime = formatDuration(program.bounty_time);
const resolutionTime = formatDuration(program.resolution_time);
const hostname = getHostname(program.url);

const pageTitle = `${program.company} Bug Bounty Program - Bug Bounties`;
const pageDescription = [
  `${program.company} bug bounty program.`,
  payout ? `Payouts: ${payout}.` : null,
  program.safe_harbor ? `Safe harbor: ${program.safe_harbor}.` : null,
  program.rewards?.length ? `Rewards: ${program.rewards.join(', ').replace(/\*/g, '')}.` : null,
].filter(Boolean).join(' ');

const breadcrumbJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://bug-bounties.as93.net/' },
    { '@type': 'ListItem', position: 2, name: program.company, item: `https://bug-bounties.as93.net/${program.slug}` },
  ],
};
---

<DefaultLayout title={pageTitle} description={pageDescription} jsonLd={breadcrumbJsonLd}>
  <Header />
  <article class="detail">
    <nav class="breadcrumbs">
      <BackLink />
    </nav>

    <!-- Header -->
    <section class="program-header">
      <FaviconImage url={program.url} alt={program.company} size="4rem"
        slug={program.slug} domains={program.domains} />
      <div>
        <h1>{program.company}</h1>
        <div class="header-links">
          <a href={program.url} target="_blank" rel="noopener noreferrer" class="external-link">
            {hostname} &rarr;
          </a>
          {program.contact && (
            <a href={program.contact} class="contact-btn">
              <Icon name={program.contact.includes('mailto:') ? 'email' : 'website'} width="14" />
              Contact
            </a>
          )}
        </div>
      </div>
    </section>

    <!-- Key Info -->
    {((program.rewards && program.rewards.length > 0) || program.safe_harbor || payout) && (
      <section class="key-info">
        <RewardBadges rewards={program.rewards || []} />
        {program.safe_harbor && (
          <Tooltip text={program.safe_harbor === 'full' ? tips.safeHarborFull : tips.safeHarborPartial}>
            <span class="tag safe-harbor">
              {program.safe_harbor === 'full' ? 'Full' : 'Partial'} Safe Harbor
            </span>
          </Tooltip>
        )}
        {payout && <Tooltip text={tips.payout}><span class="tag payout">{payout}</span></Tooltip>}
      </section>
    )}

    <!-- Program Details -->
    {(program.program || program.handle || program.managed != null || program.confidentiality_level || program.launch_date || program.allows_disclosure != null) && (
      <section class="section">
        <h2>Program Details</h2>
        <dl>
          {program.program && <><dt>Program Name</dt><dd>{program.program}</dd></>}
          {program.handle && <><dt>Handle</dt><dd>{program.handle}</dd></>}
          {program.managed != null && <><dt><Tooltip text={tips.managed}>Managed</Tooltip></dt><dd>{program.managed ? 'Yes' : 'No'}</dd></>}
          {program.confidentiality_level && <><dt><Tooltip text={tips.confidentiality}>Confidentiality</Tooltip></dt><dd>{program.confidentiality_level}</dd></>}
          {program.launch_date && <><dt>Launch Date</dt><dd>{program.launch_date}</dd></>}
          {program.allows_disclosure != null && <><dt><Tooltip text={tips.allowsDisclosure}>Allows Disclosure</Tooltip></dt><dd>{program.allows_disclosure ? 'Yes' : 'No'}</dd></>}
        </dl>
      </section>
    )}

    <!-- Response Metrics -->
    {(responseTime || bountyTime || resolutionTime || program.response_efficiency != null) && (
      <section class="section">
        <h2>Response Metrics</h2>
        <dl>
          {responseTime && <><dt><Tooltip text={tips.responseTime}>Response Time</Tooltip></dt><dd>{responseTime}</dd></>}
          {bountyTime && <><dt><Tooltip text={tips.bountyTime}>Bounty Time</Tooltip></dt><dd>{bountyTime}</dd></>}
          {resolutionTime && <><dt><Tooltip text={tips.resolutionTime}>Resolution Time</Tooltip></dt><dd>{resolutionTime}</dd></>}
          {program.response_efficiency != null && (
            <>
              <dt><Tooltip text={tips.responseEfficiency}>Response Efficiency</Tooltip></dt>
              <dd>
                <div class="efficiency-bar">
                  <div class="efficiency-fill" style={`width: ${program.response_efficiency}%`}></div>
                </div>
                <span>{program.response_efficiency}%</span>
              </dd>
            </>
          )}
        </dl>
      </section>
    )}

    <!-- Scope -->
    {program.domains && program.domains.length > 0 && (
      <section class="section">
        <h2>In-Scope Domains</h2>
        <ul class="domains">
          {program.domains.map((d) => <li>{d}</li>)}
        </ul>
      </section>
    )}

    <!-- Security -->
    {(program.pgp_key || program.securitytxt_url || program.preferred_languages) && (
      <section class="section">
        <h2>Security</h2>
        <dl>
          {program.pgp_key && <><dt><Tooltip text={tips.pgpKey}>PGP Key</Tooltip></dt><dd class="mono">{program.pgp_key}</dd></>}
          {program.securitytxt_url && (
            <>
              <dt><Tooltip text={tips.securityTxt}>security.txt</Tooltip></dt>
              <dd><a href={program.securitytxt_url} target="_blank" rel="noopener noreferrer">{program.securitytxt_url}</a></dd>
            </>
          )}
          {program.preferred_languages && <><dt><Tooltip text={tips.preferredLanguages}>Preferred Languages</Tooltip></dt><dd>{program.preferred_languages}</dd></>}
        </dl>
      </section>
    )}

    <!-- Additional -->
    {(program.hiring || program.notes || (program.sources && program.sources.length > 0)) && (
      <section class="section">
        <h2>Additional Info</h2>
        <dl>
          {program.hiring && <><dt><Tooltip text={tips.hiring}>Hiring</Tooltip></dt><dd class="hiring">Actively hiring security researchers</dd></>}
          {program.notes && <><dt>Notes</dt><dd>{program.notes}</dd></>}
          {program.sources && program.sources.length > 0 && (
            <>
              <dt>Sources</dt>
              <dd>{program.sources.join(', ')}</dd>
            </>
          )}
        </dl>
      </section>
    )}
  </article>
</DefaultLayout>

<style>
  .detail {
    width: var(--content-width);
    margin: 0 auto 2rem;
  }
  .breadcrumbs {
    margin-bottom: 1rem;
  }
  .program-header {
    display: flex;
    gap: 1.5rem;
    align-items: center;
    margin-bottom: 1.5rem;
  }
  .program-header h1 {
    margin: 0;
    color: var(--primary);
    font-size: 2rem;
  }
  .header-links {
    display: flex;
    gap: 0.75rem;
    align-items: center;
    margin-top: 0.25rem;
    flex-wrap: wrap;
  }
  .external-link {
    color: var(--muted);
    text-decoration: none;
    font-size: 0.9rem;
  }
  .external-link:hover {
    color: var(--foreground);
  }
  .contact-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    font-size: 0.8rem;
    padding: 0.15rem 0.4rem;
    background: var(--primary-muted);
    color: var(--background);
    border-radius: var(--curve);
    text-decoration: none;
    transition: var(--transition);
  }
  .contact-btn:hover {
    background: var(--primary);
  }
  .key-info {
    display: flex;
    gap: 0.75rem;
    align-items: center;
    flex-wrap: wrap;
    margin-bottom: 2rem;
    padding: 1rem;
    background: var(--background-lighter);
    border-radius: var(--curve);
  }
  .tag {
    font-size: 0.8rem;
    padding: 0.2rem 0.5rem;
    border-radius: var(--curve);
    background: var(--background-darker);
  }
  .safe-harbor {
    color: var(--success);
  }
  .payout {
    color: var(--foreground);
  }
  .section {
    background: var(--background-lighter);
    border-radius: var(--curve);
    padding: 1.25rem;
    margin-bottom: 1rem;
  }
  .section h2 {
    margin: 0 0 0.75rem;
    font-size: 1.1rem;
    color: var(--primary);
  }
  dl {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 0.5rem 1.5rem;
    margin: 0;
  }
  dt {
    color: var(--muted);
    font-size: 0.85rem;
  }
  dd {
    margin: 0;
    color: var(--foreground);
    font-size: 0.9rem;
  }
  dd a {
    color: var(--primary);
    word-break: break-all;
  }
  .mono {
    font-family: monospace;
    font-size: 0.8rem;
    word-break: break-all;
  }
  .hiring {
    color: var(--success);
  }
  .domains {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }
  .domains li {
    font-size: 0.85rem;
    padding: 0.2rem 0.5rem;
    background: var(--background-darker);
    border-radius: var(--curve);
    color: var(--foreground);
    font-family: monospace;
  }
  .efficiency-bar {
    width: 120px;
    height: 8px;
    background: var(--background-darker);
    border-radius: var(--curve);
    overflow: hidden;
    display: inline-block;
    vertical-align: middle;
    margin-right: 0.5rem;
  }
  .efficiency-fill {
    height: 100%;
    background: var(--success);
    border-radius: var(--curve);
    transition: var(--transition);
  }

  @media (max-width: 600px) {
    .program-header {
      flex-direction: column;
      align-items: flex-start;
    }
    .program-header h1 {
      font-size: 1.5rem;
    }
    dl {
      grid-template-columns: 1fr;
    }
  }
</style>
