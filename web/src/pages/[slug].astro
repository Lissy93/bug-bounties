---
import DefaultLayout from "../layouts/DefaultLayout.astro";
import Header from "../components/Header.astro";
import BackLink from "../components/BackLink.astro";
import FaviconImage from "../components/FaviconImage.svelte";
import Tooltip from "../components/Tooltip.svelte";
import Chip from "../components/Chip.svelte";
import ResultSection from "../components/results/ResultSection.astro";
import DefList from "../components/results/DefList.astro";
import PayoutTable from "../components/results/PayoutTable.astro";
import KeyInfoBar from "../components/results/KeyInfoBar.astro";
import ScopeSection from "../components/results/ScopeSection.astro";
import KevSection from "../components/results/KevSection.astro";
import { Mail, Globe, House } from "lucide-svelte";
import {
  formatDate,
  formatPayout,
  formatDuration,
  formatPayoutTable,
  formatExcludedMethod,
  getHostname,
  getHomepageUrl,
} from "../lib/format";
import { tips } from "../lib/tooltips";
import { formatRankBadge } from "../lib/tranco";
import { loadAllPrograms } from "../lib/load-all-programs";
import { companySchema } from "../lib/json-ld";
import type {
  BountyProgram,
  SecurityTxtData,
  PlatformScopeData,
  KevData,
} from "../types/Company";
import type { DefListItem } from "../components/results/DefList.astro";

export async function getStaticPaths() {
  const { programs, securityTxtMap, platformDataMap, kevMap, trancoRanks } =
    await loadAllPrograms();

  return programs.map((program) => ({
    params: { slug: program.slug },
    props: {
      program,
      securityTxt: securityTxtMap.get(program.slug) ?? null,
      platformData: platformDataMap.get(program.slug) ?? null,
      trancoRank: trancoRanks[program.slug] ?? null,
      kevData: kevMap.get(program.slug) ?? null,
    },
  }));
}

interface Props {
  program: BountyProgram;
  securityTxt: SecurityTxtData | null;
  platformData: PlatformScopeData | null;
  trancoRank: number | null;
  kevData: KevData | null;
}

const { program, securityTxt, platformData, trancoRank, kevData } = Astro.props;

const payout = formatPayout(
  program.min_payout,
  program.max_payout,
  program.currency,
);
const responseTime = formatDuration(program.response_time);
const bountyTime = formatDuration(program.bounty_time);
const resolutionTime = formatDuration(program.resolution_time);
const hostname = getHostname(program.url);
const homepageUrl = getHomepageUrl(program.url);
const showContact = program.contact && program.contact !== program.url;
const rankBadge = trancoRank ? formatRankBadge(trancoRank) : null;
const payoutTableRows = formatPayoutTable(
  program.payout_table,
  program.currency,
);

const pageTitle = `${program.company} Bug Bounty Program - Bug Bounties`;
const pageDescription = [
  `${program.company} bug bounty program.`,
  payout ? `Payouts: ${payout}.` : null,
  program.safe_harbor ? `Safe harbor: ${program.safe_harbor}.` : null,
  program.rewards?.length
    ? `Rewards: ${program.rewards.join(", ").replace(/\*/g, "")}.`
    : null,
]
  .filter(Boolean)
  .join(" ");

const breadcrumbJsonLd = companySchema({
  company: program.company,
  slug: program.slug,
  url: homepageUrl || program.url,
  description: program.description,
});

/* Filter helper that TypeScript can narrow correctly */
function items(...entries: (DefListItem | null | undefined)[]): DefListItem[] {
  return entries.filter((e): e is DefListItem => e != null);
}

/* Build DefList items for each section */
const programDetails = items(
  program.program ? { label: "Program Name", value: program.program } : null,
  program.handle ? { label: "Handle", value: program.handle } : null,
  program.managed != null
    ? {
        label: "Managed",
        value: program.managed ? "Yes" : "No",
        tooltip: tips.managed,
      }
    : null,
  program.confidentiality_level
    ? {
        label: "Confidentiality",
        value: program.confidentiality_level,
        tooltip: tips.confidentiality,
      }
    : null,
  program.launch_date
    ? { label: "Launch Date", value: program.launch_date }
    : null,
  program.allows_disclosure != null
    ? {
        label: "Allows Disclosure",
        value: program.allows_disclosure ? "Yes" : "No",
        tooltip: tips.allowsDisclosure,
      }
    : null,
  program.disclosure_timeline_days != null
    ? {
        label: "Disclosure Window",
        value: `${program.disclosure_timeline_days} days`,
        tooltip: tips.disclosureTimeline,
      }
    : null,
  program.response_sla_days != null
    ? {
        label: "Response SLA",
        value: `${program.response_sla_days} business days`,
        tooltip: tips.responseSla,
      }
    : null,
  program.reporting_url
    ? {
        label: "Report Submission",
        value: program.reporting_url,
        href: program.reporting_url,
        tooltip: tips.reportingUrl,
      }
    : null,
);

const responseMetrics = items(
  responseTime
    ? {
        label: "Response Time",
        value: responseTime,
        tooltip: tips.responseTime,
      }
    : null,
  bountyTime
    ? { label: "Bounty Time", value: bountyTime, tooltip: tips.bountyTime }
    : null,
  resolutionTime
    ? {
        label: "Resolution Time",
        value: resolutionTime,
        tooltip: tips.resolutionTime,
      }
    : null,
);

const legalItems = items(
  program.legal_terms_url
    ? {
        label: "Legal Terms",
        value: program.legal_terms_url,
        href: program.legal_terms_url,
        tooltip: tips.legalTerms,
      }
    : null,
);

const recognitionItems = items(
  program.hall_of_fame_url
    ? {
        label: "Hall of Fame",
        value: program.hall_of_fame_url,
        href: program.hall_of_fame_url,
        tooltip: tips.hallOfFame,
      }
    : null,
  program.swag_details && !payoutTableRows
    ? {
        label: "Swag",
        value: program.swag_details,
        tooltip: tips.swagDetails,
      }
    : null,
);

const securityItems = items(
  program.pgp_key
    ? {
        label: "PGP Key",
        value: program.pgp_key,
        mono: true,
        tooltip: tips.pgpKey,
      }
    : null,
  program.securitytxt_url
    ? {
        label: "security.txt",
        value: program.securitytxt_url,
        href: program.securitytxt_url,
        tooltip: tips.securityTxt,
      }
    : null,
  program.preferred_languages
    ? {
        label: "Preferred Languages",
        value: program.preferred_languages,
        tooltip: tips.preferredLanguages,
      }
    : null,
);

const additionalItems = items(
  program.hiring
    ? {
        label: "Hiring",
        value: "Actively hiring security researchers",
        color: "hiring",
        tooltip: tips.hiring,
      }
    : null,
  program.notes ? { label: "Notes", value: program.notes } : null,
  program.sources && program.sources.length > 0
    ? { label: "Sources", value: program.sources.join(", ") }
    : null,
);

const securityTxtItems = securityTxt
  ? items(
      securityTxt.contact && securityTxt.contact.length > 0
        ? {
            label: "Contact",
            value: securityTxt.contact.join(", "),
            tooltip: tips.securityTxtContact,
          }
        : null,
      securityTxt.encryption && securityTxt.encryption.length > 0
        ? {
            label: "Encryption",
            value: securityTxt.encryption.join(", "),
            href: securityTxt.encryption[0],
          }
        : null,
      securityTxt.policy
        ? {
            label: "Policy",
            value: securityTxt.policy,
            href: securityTxt.policy,
          }
        : null,
      securityTxt.hiring
        ? {
            label: "Hiring",
            value: securityTxt.hiring,
            href: securityTxt.hiring,
          }
        : null,
      securityTxt.acknowledgments
        ? {
            label: "Acknowledgments",
            value: securityTxt.acknowledgments,
            href: securityTxt.acknowledgments,
          }
        : null,
      securityTxt.preferredLanguages
        ? {
            label: "Languages",
            value: securityTxt.preferredLanguages,
          }
        : null,
      securityTxt.expires
        ? {
            label: "Expires",
            value: formatDate(securityTxt.expires),
            color: securityTxt.is_expired ? "expired-text" : undefined,
          }
        : null,
    )
  : [];

const rulesItems = items(
  program.requires_account != null
    ? {
        label: "Requires Account",
        value: program.requires_account ? "Yes" : "No",
        tooltip: tips.requiresAccount,
      }
    : null,
  program.testing_policy_url
    ? {
        label: "Testing Policy",
        value: program.testing_policy_url,
        href: program.testing_policy_url,
        tooltip: tips.testingPolicy,
      }
    : null,
);

const hasRulesSection =
  rulesItems.length > 0 ||
  (program.excluded_methods && program.excluded_methods.length > 0);

const hasProgramDetails = program.description || programDetails.length > 0;

const showResponseEfficiency = program.response_efficiency != null;
const hasResponseMetrics = responseMetrics.length > 0 || showResponseEfficiency;
---

<DefaultLayout
  title={pageTitle}
  description={pageDescription}
  jsonLd={breadcrumbJsonLd}
>
  <Header />
  <article class="detail-page">
    <nav class="breadcrumbs" aria-label="Breadcrumb">
      <BackLink />
    </nav>

    <!-- Header -->
    <section class="program-header">
      <FaviconImage
        url={program.url}
        alt={program.company}
        size="4rem"
        slug={program.slug}
        domains={program.domains}
      />
      <div>
        <div class="title-row">
          <h1>{program.company}</h1>
          {
            rankBadge && (
              <Chip
                color="var(--accent)"
                tooltip={tips.trancoRank}
                size="sm"
                filled
              >
                <span class="rank-text">{rankBadge}</span>
              </Chip>
            )
          }
        </div>
        <div class="header-links">
          <a
            href={program.url}
            target="_blank"
            rel="noopener noreferrer"
            class="external-link"
          >
            {hostname} &rarr;
          </a>
          {
            homepageUrl && (
              <a
                href={homepageUrl}
                target="_blank"
                rel="noopener noreferrer"
                class="header-btn"
              >
                <House size={14} />
                Homepage
              </a>
            )
          }
          {
            showContact && (
              <a href={program.contact} class="header-btn">
                {program.contact?.includes("mailto:") ? (
                  <Mail size={14} />
                ) : (
                  <Globe size={14} />
                )}
                Contact
              </a>
            )
          }
        </div>
      </div>
    </section>

    <KeyInfoBar
      programType={program.program_type}
      status={program.status}
      rewards={program.rewards}
      safeHarbor={program.safe_harbor}
      payout={payout}
    />

    {
      hasProgramDetails && (
        <ResultSection heading="Program Details">
          {program.description && (
            <p class="program-description">{program.description}</p>
          )}
          {programDetails.length > 0 && <DefList items={programDetails} />}
        </ResultSection>
      )
    }

    {
      hasResponseMetrics && (
        <ResultSection heading="Response Metrics">
          {responseMetrics.length > 0 && <DefList items={responseMetrics} />}
          {showResponseEfficiency && (
            <div class="efficiency-row">
              <span class="efficiency-label">
                <Tooltip text={tips.responseEfficiency}>
                  Response Efficiency
                </Tooltip>
              </span>
              <div class="efficiency-bar">
                <div
                  class="efficiency-fill"
                  style={`width: ${program.response_efficiency}%`}
                />
              </div>
              <span class="efficiency-value">
                {program.response_efficiency}%
              </span>
            </div>
          )}
        </ResultSection>
      )
    }

    {
      payoutTableRows && (
        <ResultSection heading="Payout Structure">
          <Tooltip slot="badge" text={tips.payoutTable} />
          <PayoutTable
            rows={payoutTableRows}
            swagDetails={program.swag_details}
          />
        </ResultSection>
      )
    }

    {
      hasRulesSection && (
        <ResultSection heading="Rules & Testing">
          {rulesItems.length > 0 && <DefList items={rulesItems} />}
          {program.excluded_methods && program.excluded_methods.length > 0 && (
            <div class="sub-section">
              <h3>
                <Tooltip text={tips.excludedMethods}>Excluded Methods</Tooltip>
              </h3>
              <div class="chip-group">
                {program.excluded_methods.map((m) => (
                  <Chip color="var(--danger)" size="sm">
                    {formatExcludedMethod(m)}
                  </Chip>
                ))}
              </div>
            </div>
          )}
        </ResultSection>
      )
    }

    <ScopeSection
      platformData={platformData}
      scope={program.scope}
      domains={program.domains}
      outOfScope={program.out_of_scope}
    />

    {kevData && <KevSection kevData={kevData} />}

    {
      (legalItems.length > 0 ||
        (program.standards && program.standards.length > 0)) && (
        <ResultSection heading="Legal & Standards">
          {legalItems.length > 0 && <DefList items={legalItems} />}
          {program.standards && program.standards.length > 0 && (
            <div class="sub-section">
              <h3>
                <Tooltip text={tips.standards}>Standards</Tooltip>
              </h3>
              <div class="chip-group">
                {program.standards.map((s) => (
                  <Chip color="var(--muted)" size="sm">
                    {s}
                  </Chip>
                ))}
              </div>
            </div>
          )}
        </ResultSection>
      )
    }

    {
      recognitionItems.length > 0 && (
        <ResultSection heading="Recognition">
          <DefList items={recognitionItems} />
        </ResultSection>
      )
    }

    {
      securityItems.length > 0 && (
        <ResultSection heading="Security">
          <DefList items={securityItems} />
        </ResultSection>
      )
    }

    {
      securityTxt && securityTxtItems.length > 0 && (
        <ResultSection heading="security.txt">
          {securityTxt.is_expired && (
            <Chip
              slot="badge"
              color="var(--warning)"
              tooltip={tips.securityTxtExpired}
              size="sm"
              filled
            >
              expired
            </Chip>
          )}
          <DefList items={securityTxtItems} />
          {securityTxt.raw_url && (
            <a
              href={securityTxt.raw_url}
              target="_blank"
              rel="noopener noreferrer"
              class="text-link"
            >
              View raw security.txt &rarr;
            </a>
          )}
        </ResultSection>
      )
    }

    {
      additionalItems.length > 0 && (
        <ResultSection heading="Additional Info">
          <DefList items={additionalItems} />
        </ResultSection>
      )
    }
  </article>
</DefaultLayout>

<style>
  @import "../styles/results.css";

  .program-header {
    display: flex;
    gap: 1.5rem;
    align-items: center;
    margin-bottom: 1.5rem;

    & h1 {
      margin: 0;
      color: var(--primary);
      font-size: 2rem;
    }
  }

  .title-row {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .rank-text {
    font-weight: 600;
  }

  .header-links {
    display: flex;
    gap: 0.75rem;
    align-items: center;
    margin-top: 0.25rem;
    flex-wrap: wrap;
  }

  .external-link {
    color: var(--muted);
    text-decoration: none;
    font-size: 0.9rem;

    &:hover {
      color: var(--foreground);
    }
  }

  .header-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    font-size: 0.8rem;
    padding: 0.15rem 0.4rem;
    background: var(--primary-muted);
    color: var(--background);
    border-radius: var(--curve);
    text-decoration: none;
    transition: var(--transition);

    &:hover {
      background: var(--primary);
    }
  }

  .program-description {
    color: var(--foreground);
    font-size: 0.9rem;
    line-height: 1.5;
    margin: 0 0 0.75rem;
  }

  .efficiency-row {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-top: 0.5rem;
    font-size: 0.85rem;
  }

  .efficiency-label {
    color: var(--muted);
  }

  .efficiency-bar {
    width: 120px;
    height: 8px;
    background: var(--background-darker);
    border-radius: var(--curve);
    overflow: hidden;
  }

  .efficiency-fill {
    height: 100%;
    background: var(--success);
    border-radius: var(--curve);
    transition: var(--transition);
  }

  .efficiency-value {
    color: var(--foreground);
  }

  .text-link {
    margin-top: 0.75rem;
  }

  @media (max-width: 600px) {
    .program-header {
      flex-direction: column;
      align-items: flex-start;

      & h1 {
        font-size: 1.5rem;
      }
    }
  }
</style>
