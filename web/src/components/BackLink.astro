---
interface Props {
  href?: string;
  label?: string;
}

const { href = "/", label = "Back to all programs" } = Astro.props;
---

<a class="back-link" href={href}>&larr; {label}</a>

<style>
  .back-link {
    display: inline-block;
    color: var(--primary);
    text-decoration: none;
    font-size: 0.95rem;
    padding: 0.5rem 0;
    transition: var(--transition);

    &:hover {
      text-decoration: underline;
    }
  }
</style>
