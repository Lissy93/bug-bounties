---
import LinkGrid, { type LinkGridItem } from "./LinkGrid.astro";

interface Props {
  /** If set, only the most recent N guides will be rendered. */
  limit?: number;
}

const { limit } = Astro.props;

const guideFiles = import.meta.glob("../../pages/learn/*.md", { eager: true });
const allGuides = Object.values(guideFiles)
  .map((mod: any) => ({
    title: mod.frontmatter.title as string,
    description: mod.frontmatter.description as string,
    url: mod.url as string,
    date: mod.frontmatter.date as string,
  }))
  .sort((a, b) => new Date(b.date).getTime() - new Date(a.date).getTime());

const items: LinkGridItem[] = (limit ? allGuides.slice(0, limit) : allGuides).map(
  ({ title, description, url }) => ({ title, description, url }),
);
---

<LinkGrid items={items} external={false} />
