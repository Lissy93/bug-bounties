---
import LinkGrid, { type LinkGridItem } from "./LinkGrid.astro";

interface Props {
  /** If set, only the first N tools will be rendered. */
  limit?: number;
  /** Optional target. When provided, each tool's searchLink is filled in. */
  website?: string;
}

const { limit, website } = Astro.props;

function normalizeTarget(value?: string) {
  if (!value) return null;
  const trimmed = value.trim();
  if (!trimmed) return null;
  let domain: string;
  let fullUrl: string;
  try {
    const u = new URL(trimmed.includes("://") ? trimmed : `https://${trimmed}`);
    domain = u.hostname.replace(/^www\./, "");
    fullUrl = `${u.protocol}//${domain}${u.pathname === "/" ? "" : u.pathname}`;
  } catch {
    domain = trimmed.replace(/^www\./, "").split("/")[0];
    if (!domain) return null;
    fullUrl = `https://${domain}`;
  }
  return { domain, fullUrl, urlEncoded: encodeURIComponent(fullUrl) };
}

const target = normalizeTarget(website);

function resolveHref(link: string, searchLink?: string) {
  if (!target || !searchLink) return link;
  return searchLink
    .replace(/\{URL_ENCODED\}/g, target.urlEncoded)
    .replace(/\{URL\}/g, target.fullUrl)
    .replace(/\{DOMAIN\}/g, target.domain);
}

interface Tool {
  title: string;
  link: string;
  icon: string;
  description: string;
  searchLink?: string;
}

const allResources: Tool[] = [
