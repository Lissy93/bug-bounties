const tools = limit ? allResources.slice(0, limit) : allResources;

const items: LinkGridItem[] = tools.map((t) => ({
  title: t.title,
  url: resolveHref(t.link, t.searchLink),
  description: t.description,
  icon: t.icon,
}));
---

<LinkGrid items={items} />
