    {" " + year}
  </div>
  <nav aria-label="Footer">
    <a href="/about">About</a>
    <a href="https://github.com/Lissy93/bug-bounties">Source</a>
    <a href="https://github.com/Lissy93/bug-bounties/blob/main/LICENSE"
      >License</a
    >
