---
const year = new Date().getFullYear();
const ext = { target: "_blank", rel: "noopener noreferrer" };
const REPO = "https://github.com/Lissy93/bug-bounties";

const navLinks: { href: string; label: string; external?: boolean }[] = [
  { href: "/about", label: "About" },
  { href: REPO, label: "Source", external: true },
  { href: `${REPO}/blob/main/LICENSE`, label: "License", external: true },
  {
    href: `${REPO}/blob/main/.github/CONTRIBUTING.md`,
    label: "Contribute",
    external: true,
  },
  {
    href: "https://apps.aliciasykes.com",
    label: "More Apps...",
    external: true,
  },
];
---

<footer>
  <div>
    <a href="https://bug-bounties.as93.net">Bug Bounties</a> is licensed under
    <a href={`${REPO}/blob/main/LICENSE`} {...ext}>MIT</a> ©
    <a href="https://github.com/Lissy93" {...ext}>Alicia Sykes</a>
    {" " + year}
  </div>
  <nav aria-label="Footer">
    {
      navLinks.map(({ href, label, external }) => (
        <a href={href} {...(external ? ext : {})}>
          {label}
        </a>
      ))
    }
  </nav>
</footer>

<style>
  footer {
    width: 100%;
    margin-top: 2rem;
    background: var(--background-lighter);
    text-align: center;
    color: var(--foreground);
    padding: 0.5rem 0;
    box-shadow: 0 -1px 2px var(--background-darker);
    display: flex;
    justify-content: space-between;
  }
  footer a {
    color: var(--primary);
  }
  footer a:hover {
    filter: brightness(1.25);
  }
  footer div,
  footer nav {
    padding: 0 1rem;
  }
  footer nav a + a::before {
    content: "|";
    margin: 0 0.35rem;
    color: var(--muted);
  }
  @media only screen and (max-width: 800px) {
    footer {
      flex-direction: column;
    }
  }
</style>
