---
import { Info } from "lucide-svelte";

interface Props {
  text: string;
}

const { text } = Astro.props;
---

<p class="disclaimer">
  <Info size={12} />
  <span>{text}</span>
</p>

<style>
  .disclaimer {
    display: flex;
    align-items: flex-start;
    gap: 0.35rem;
    margin: 0.5rem 0 0;
    padding: 0.4rem 0.6rem;
    font-size: 0.75rem;
    line-height: 1.4;
    color: var(--muted);
    background: var(--background-darker);
    border-radius: var(--curve);
    border-left: 2px solid var(--warning);

    & :global(svg) {
      flex-shrink: 0;
      margin-top: 1px;
      color: var(--warning);
    }
  }
</style>
